{
  "name": "aura-ai-chat",
  "version": "1.0.0",
  "description": "Production-grade, framework-agnostic AI chat widget built as a Web Component library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles/tokens.css"
  },
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dev": "vite",
    "analyze": "cem analyze --litelement"
  },
  "dependencies": {
    "@material/web": "^2.4.1",
    "dompurify": "^3.2.0",
    "lit": "^3.3.2",
    "marked": "^15.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "license": "MIT"
}